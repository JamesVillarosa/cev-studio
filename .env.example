# ---- Supabase ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Bypasses RLS — never expose to the browser or commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin gate (/admin) ----
# Password to view contact submissions.
ADMIN_PASSWORD=choose-a-strong-password
# Secret used to sign the admin session cookie. Generate with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET=generate-a-64-char-hex-secret
